[submodule "sw/FreeRTOS-Kernel"]
	path = sw/FreeRTOS-Kernel
	url = https://github.com/FreeRTOS/FreeRTOS-Kernel.git

[submodule "sw/apps/coremark/coremark"]
	path = sw/apps/coremark/coremark
	url = https://github.com/eembc/coremark.git

[submodule "sw/apps/arch_test/riscv-arch-test"]
	path = sw/apps/arch_test/riscv-arch-test
	url = https://github.com/riscv-non-isa/riscv-arch-test.git
[submodule "sw/apps/riscv_tests/riscv-tests"]
	path = sw/apps/riscv_tests/riscv-tests
	url = https://github.com/riscv-software-src/riscv-tests.git
[submodule "sw/apps/coremark_pro/coremark-pro"]
	path = sw/apps/coremark_pro/coremark-pro
	url = https://github.com/eembc/coremark-pro.git
[submodule "linux/buildroot"]
	path = linux/buildroot
	url = https://github.com/buildroot/buildroot.git

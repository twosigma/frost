# Makefile for riscv-tests benchmark compilation on Frost
#
# Usage: make -f Makefile.bench BENCH=median
#        make -f Makefile.bench BENCH=mm
#
# Each benchmark is compiled with:
#   - crt0_bench.S (Frost startup: FPU init, data copy, calls _init)
#   - syscalls_frost.c (UART-based exit/printf, replaces tohost)
#   - The benchmark's own .c files
#   - Linked with -lm -lgcc for math library support

BENCH ?=

# Architecture - matches common.mk
ARCH = rv32imafdc_zicsr_zicntr_zifencei_zba_zbb_zbs_zicond_zbkb_zihintpause
ABI  = ilp32d

# Tools
RISCV_PREFIX ?= riscv-none-elf-
CC      = $(RISCV_PREFIX)gcc
OBJCOPY = $(RISCV_PREFIX)objcopy
OBJDUMP = $(RISCV_PREFIX)objdump

# Benchmark source directory
BENCH_DIR = riscv-tests/benchmarks

# Compiler flags (matching upstream benchmark build)
CFLAGS = -march=$(ARCH) -mabi=$(ABI) \
         -U_FORTIFY_SOURCE -DPREALLOCATE=1 -mcmodel=medany -static \
         -std=gnu99 -O2 -ffast-math -fno-common -fno-builtin-printf \
         -fno-tree-loop-distribute-patterns \
         -Wno-implicit-int -Wno-implicit-function-declaration

# Include paths
INCLUDES = -I. -I$(BENCH_DIR)/../env -I$(BENCH_DIR)/common -I$(BENCH_DIR)/$(BENCH)

# Memory configuration -- selects the linker script and, for ddr, the ROM boot
# stub plus the sections split out of the low BRAM image into the DDR image
# (sw_ddr.mem; tests/test_riscv_tests.py passes this via MEM_CONFIG):
#   bram (default): code + data + heap in low BRAM.
#   ddr:            a ROM boot stub far-jumps to the DDR-resident benchmark;
#                   code + data + heap live in the cached DDR region (exercises
#                   the L1I fetch path and the D-side cached tier).
MEM_CONFIG ?= bram

ifeq ($(MEM_CONFIG),bram)
LINKER_SCRIPT = link_riscv_tests.ld
BOOT_STUB     =
DDR_SECTIONS  =
else ifeq ($(MEM_CONFIG),ddr)
LINKER_SCRIPT = link_riscv_tests_ddr.ld
BOOT_STUB     = crt0_riscv_tests_ddr.S
DDR_SECTIONS  = .text.init .text .rodata .data .sdata .tohost
else
$(error MEM_CONFIG must be one of: bram, ddr (got '$(MEM_CONFIG)'))
endif

LDFLAGS = -static -nostdlib -nostartfiles -lm -lgcc -T $(LINKER_SCRIPT)

# Output files
EXECUTABLE_ELF_FILE  = sw.elf
VERILOG_HEX_FILE     = sw.mem
DDR_VERILOG_HEX_FILE = sw_ddr.mem
RAW_BINARY_FILE      = sw.bin
DISASSEMBLY_FILE     = sw.S

# Startup and syscall shim
CRT0 = crt0_bench.S
SYSCALLS = syscalls_frost.c

# Frost standard library (single source of truth in sw/lib). syscalls_frost.c
# no longer carries its own libc copies; the canonical memcpy/memset/str*/
# malloc/free/calloc/realloc/atol/abs come from here. Compiled as isolated
# objects with their own include path so the benchmark sources keep using the
# toolchain's <string.h>/<stdlib.h> (no header shadowing).
LIB_DIR = ../../lib
LIB_OBJ = frostlib_string.o frostlib_memory.o frostlib_stdlib.o frostlib_ctype.o

# Find benchmark source files (all .c and .S in the benchmark directory)
BENCH_C_SRC = $(wildcard $(BENCH_DIR)/$(BENCH)/*.c)
BENCH_S_SRC = $(wildcard $(BENCH_DIR)/$(BENCH)/*.S)

# Build targets
all: $(VERILOG_HEX_FILE) $(DDR_VERILOG_HEX_FILE) $(DISASSEMBLY_FILE)

# Frost library objects: compiled with the lib's own include path in isolation.
frostlib_%.o: $(LIB_DIR)/src/%.c
	$(CC) $(CFLAGS) -I$(LIB_DIR)/include -c $< -o $@

# The ddr config additionally links a ROM boot stub ($(BOOT_STUB)) that
# far-jumps to crt0_bench's _start in the DDR region.
$(EXECUTABLE_ELF_FILE): $(BOOT_STUB) $(CRT0) $(SYSCALLS) $(BENCH_C_SRC) $(BENCH_S_SRC) $(LIB_OBJ) $(LINKER_SCRIPT)
ifndef BENCH
	$(error BENCH is not set. Usage: make -f Makefile.bench BENCH=median)
endif
	$(CC) $(CFLAGS) $(INCLUDES) \
		$(BOOT_STUB) $(CRT0) $(SYSCALLS) $(BENCH_C_SRC) $(BENCH_S_SRC) $(LIB_OBJ) \
		$(LDFLAGS) -o $@

# Low BRAM image: everything NOT split out to DDR (the bram config keeps the
# whole image; the ddr config keeps only the ROM boot stub).
$(VERILOG_HEX_FILE): $(EXECUTABLE_ELF_FILE)
	$(OBJCOPY) -O verilog --verilog-data-width 4 -R .comment -R .note.gnu.build-id \
		$(foreach s,$(DDR_SECTIONS),-R $(s)) $< $@

# DDR image, region-relative addresses. With no DDR sections (bram config) emit
# an empty image so the harness symlink and the sim's $readmemh stay happy.
$(DDR_VERILOG_HEX_FILE): $(EXECUTABLE_ELF_FILE)
ifeq ($(strip $(DDR_SECTIONS)),)
	: > $@
else
	$(OBJCOPY) -O verilog --verilog-data-width 4 \
		$(foreach s,$(DDR_SECTIONS),-j $(s)) \
		--change-addresses -0x80000000 $< $@
endif

$(RAW_BINARY_FILE): $(EXECUTABLE_ELF_FILE)
	$(OBJCOPY) -O binary -R .comment -R .note.gnu.build-id $< $@

$(DISASSEMBLY_FILE): $(EXECUTABLE_ELF_FILE)
	$(OBJDUMP) -d $< > $@

clean:
	rm -f $(EXECUTABLE_ELF_FILE) $(VERILOG_HEX_FILE) $(DDR_VERILOG_HEX_FILE) $(RAW_BINARY_FILE) $(DISASSEMBLY_FILE) $(LIB_OBJ)

.PHONY: all clean
